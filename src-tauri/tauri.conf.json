{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stoa",
  "version": "1.0.0",
  "identifier": "com.openclaw.stoa-gui",
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Stoa | Operator Terminal",
        "width": 1280,
        "height": 800,
        "transparent": true
      }
    ]
  },
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  }
}
